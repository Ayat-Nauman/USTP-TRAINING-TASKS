interface mux_interface #(parameter N);
logic [N-1:0] in;
logic out;
logic [($clog2(N)-1):0]ctrl;

// MODPORT DUT
modport dut(
input in, ctrl,
output out
);

// MODPORT DRIVER
modport driver(
output in, ctrl
);

// MODPORT MONITOR
modport monitor(
input in, out, ctrl
);

endinterface
